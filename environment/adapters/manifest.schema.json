{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Playground Adapter Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "status",
    "target_path",
    "source_repository",
    "source_path",
    "source_commit",
    "package_name",
    "python_package",
    "generated_output",
    "smoke_commands",
    "excluded_source_paths"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "name": { "type": "string" },
    "status": { "enum": ["enabled", "experimental", "archived"] },
    "target_path": { "type": "string", "pattern": "^environment/adapters/[^/]+$" },
    "source_repository": { "type": "string" },
    "source_path": { "type": "string" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "owner": { "type": "string" },
    "package_name": { "type": "string" },
    "python_package": { "type": "string" },
    "generated_output": { "type": "string", "pattern": "^environment/adapters/[^/]+/_generated/$" },
    "smoke_commands": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "required_external_data": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_credentials": {
      "type": "array",
      "items": { "type": "string" }
    },
    "excluded_source_paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
