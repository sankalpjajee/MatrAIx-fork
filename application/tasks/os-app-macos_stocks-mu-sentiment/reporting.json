{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": {
        "contextType": "task_outcome"
      },
      "summaryDirectives": [
        {
          "id": "task_outcome.explanation_by_status",
          "title": "Outcome explanation by status",
          "targetFacetKey": "outcome_explanation",
          "groupByFacetKey": "outcome_status",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        },
        {
          "id": "task_outcome.explanation_by_failure_reason",
          "title": "Outcome explanation by failure reason",
          "targetFacetKey": "outcome_explanation",
          "groupByFacetKey": "primary_failure_reason",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ],
      "judgeDirectives": [
        {
          "id": "task_outcome.failure_signal_scan",
          "title": "Failure signal scan",
          "targetFacetKey": "outcome_explanation",
          "groupByFacetKey": "primary_failure_reason",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Read each outcome explanation and classify which reusable execution-failure signals are explicitly present.",
          "rubric": "Mark a signal true only when the explanation clearly states or strongly implies that signal.",
          "signals": [
            {
              "key": "navigation_signal",
              "label": "Navigation issue",
              "valueType": "boolean"
            },
            {
              "key": "grounding_signal",
              "label": "Grounding issue",
              "valueType": "boolean"
            },
            {
              "key": "recovery_signal",
              "label": "Recovery failure",
              "valueType": "boolean"
            },
            {
              "key": "instruction_reading_signal",
              "label": "Instruction-reading issue",
              "valueType": "boolean"
            }
          ]
        }
      ]
    },
    {
      "match": {
        "contextType": "goal_component"
      },
