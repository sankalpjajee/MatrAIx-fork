{
  "schemaVersion": "application-task-interface-v1",
  "applicationTypes": {
    "survey": {
      "status": "active",
      "driver": "survey_form",
      "canonicalTask": "application/tasks/persona-survey",
      "artifactContract": [
        "survey_result",
        "answers",
        "trajectory",
        "metrics"
      ]
    },
    "chatbot": {
      "status": "active",
      "driver": "chat_api_controller",
      "canonicalTask": "application/tasks/recommender-agent_chat_api",
      "artifactContract": [
        "transcript",
        "recommendation_result",
        "persona_self_report",
        "evaluation_result"
      ]
    },
    "web": {
      "status": "active",
      "driver": "browser_or_computer_use",
      "canonicalTask": "application/tasks/example-web-playwright_books-interest",
      "artifactContract": [
        "trajectory",
        "application_result",
        "objective_result",
        "persona_self_report"
      ]
    },
    "appworld": {
      "status": "active",
      "driver": "benchflow_appworld_agent",
      "canonicalTask": "external:appworld",
      "artifactContract": [
        "appworld_result",
        "trace",
        "score",
        "persona_self_report"
      ]
    }
